# Database (SQLite for local dev; swap to Postgres for production)
DATABASE_URL="file:./prisma/dev.db"

# ARC testnet — YOU fill these from your RPC/faucet setup
ARC_RPC_URL=""
ARC_CHAIN_ID=""
NEXT_PUBLIC_ARC_CHAIN_ID=""
NEXT_PUBLIC_ARC_EXPLORER_URL=""   # base URL for tx explorer links, e.g. https://explorer.arc.io/tx/

# Tokens / contracts
USDC_ADDRESS=""
ESCROW_ADDRESS=""
NEXT_PUBLIC_ESCROW_ADDRESS=""

# Deploy
DEPLOYER_PRIVATE_KEY=""

# Explorer (server-side, used for receipt tx links)
ARC_EXPLORER_URL=""               # e.g. https://testnet.arcscan.app  (explorerTxUrl appends /tx/<hash>)

# Circle stack — set these to flip the Wallets/Gateway/StableFX seams to LIVE
CIRCLE_API_KEY=""                 # Wallets + Gateway (+ StableFX execute)
# StableFX: with no live source, FX_SOURCE_URL empty → quote source = "fallback".
# Set a StableFX-shaped quote endpoint to tag source = "stablefx".
FX_SOURCE_URL=""
FX_FALLBACK_RATE="56.00"

# Demo seed
SEED_PAYER_WALLET="0x..."         # Northwind's testnet wallet address for the demo seed
DEMO_FREELANCER_ID=""             # Set after seeding — Maya's party ID, used as hardcoded session
